# Database Configuration (Neon PostgreSQL)
# Get this from https://console.neon.tech/
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AI Configuration (OpenRouter)
# Get this from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI Configuration (Google Gemini - Legacy)
# Get this from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
# Can also use public key if client-side fallback is needed
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# App URL (Optional - Default: http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Configuration (Optional)
# VEREL_ANALYTICS_ID=
